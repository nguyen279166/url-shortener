generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ShortLink {
  id          String       @id @default(uuid()) @db.Uuid
  slug        String       @unique @db.VarChar(64)
  originalUrl String       @db.Text
  isActive    Boolean      @default(true)
  expiresAt   DateTime?    @db.Timestamptz(3)
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(3)
  clicks      ClickEvent[]

  @@index([createdAt])
  @@map("short_links")
}

model ClickEvent {
  id          BigInt    @id @default(autoincrement())
  shortLinkId String    @db.Uuid
  clickedAt   DateTime  @default(now()) @db.Timestamptz(3)
  referrer    String?   @db.Text
  userAgent   String?   @db.Text
  ipHash      String?   @db.VarChar(64)
  shortLink   ShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([shortLinkId, clickedAt])
  @@map("click_events")
}
