{
  "name": "url-shortener",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @url-shortener/api --filter @url-shortener/web dev",
    "dev:api": "pnpm --filter @url-shortener/api dev",
    "dev:web": "pnpm --filter @url-shortener/web dev",
    "build": "pnpm -r build",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:generate": "pnpm --filter @url-shortener/api db:generate",
    "db:migrate": "pnpm --filter @url-shortener/api db:migrate",
    "db:studio": "pnpm --filter @url-shortener/api db:studio",
    "db:validate": "pnpm --filter @url-shortener/api db:validate",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  }
}
